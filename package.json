{
  "name": "social-network",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend,cdn,proxy -c blue,green,magenta,yellow \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:cdn\" \"npm:dev:proxy\"",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:cdn": "npm --prefix cdn run start:dev",
    "dev:proxy": "npm --prefix auth-proxy run start:dev",
    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install && npm --prefix cdn install && npm --prefix auth-proxy install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
